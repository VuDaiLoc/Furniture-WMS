                <div class="user-info">
                    <span>Xin chào, @Context.Session.GetString("Username")</span>
                    <a href="/Account/Logout" class="btn btn-danger btn-sm mt-2">Đăng xuất</a>
                </div>
            }
            else
            {
                <a href="/Account/Login" class="btn btn-primary btn-sm mt-2">Đăng nhập</a>
            }
        </div>
    }

