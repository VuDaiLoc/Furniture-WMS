<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Luxury WMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://kit.fontawesome.com/a076d05399.js"></script>
</head>
<body>
    <header class="main-header">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <!-- Logo -->
            <a class="brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                <img src="~/lib/images/Logo/cropped_logo_no_border.png" alt="Luxury WMS Logo" class="logo">
                <span class="brand-name">Luxury WMS</span>
            </a>

            <!-- Thanh tìm kiếm -->
            <div class="search-container">
                <div class="search-bar">
                    <input type="text" class="search-input" placeholder="Tìm kiếm...">
                    <button class="search-btn">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>

            <!-- Nút đăng nhập -->
            <div class="login-btn">
                <div class="login-btn">
                    <a asp-controller="Account" asp-action="Login" class="btn-login">Đăng nhập</a>
                </div>
            </div>
        </div>
    </header>

    <div class="container">
        <main role="main">
            <!-- Slider ảnh nền -->
            <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="~/lib/images/Ảnh Trang Chủ/001.jpg" class="d-block w-100 slider-img" alt="Slide 1">
                        <div class="carousel-caption">
                            <h1>THIẾT KẾ NỘI THẤT</h1>
                            <p>Tinh tế & Hiện đại</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/lib/images/Ảnh Trang Chủ/002.jpg" class="d-block w-100 slider-img" alt="Slide 2">
                        <div class="carousel-caption">
                            <h1>KHÔNG GIAN SANG TRỌNG</h1>
                            <p>Sáng tạo không giới hạn</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/lib/images/Ảnh Trang Chủ/003.jpg" class="d-block w-100 slider-img" alt="Slide 3">
                        <div class="carousel-caption">
                            <h1>THẨM MỸ ĐỘC ĐÁO</h1>
                            <p>Thiết kế khác biệt, đẳng cấp</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/lib/images/Ảnh Trang Chủ/004.jpg" class="d-block w-100 slider-img" alt="Slide 4">
                        <div class="carousel-caption">
                            <h1>NGHỆ THUẬT KHÔNG GIAN</h1>
                            <p>Hiện đại & Tinh tế</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/lib/images/Ảnh Trang Chủ/005.jpg" class="d-block w-100 slider-img" alt="Slide 5">
                        <div class="carousel-caption">
                            <h1>ĐẲNG CẤP THƯỢNG LƯU</h1>
                            <p>Trải nghiệm không gian xa hoa</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/lib/images/Ảnh Trang Chủ/006.jpg" class="d-block w-100 slider-img" alt="Slide 6">
                        <div class="carousel-caption">
                            <h1>THIẾT KẾ CÁ NHÂN HOÁ</h1>
                            <p>Phong cách riêng biệt</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/lib/images/Ảnh Trang Chủ/007.jpg" class="d-block w-100 slider-img" alt="Slide 7">
                        <div class="carousel-caption">
                            <h1>CHẤT LƯỢNG HOÀN HẢO</h1>
                            <p>Vật liệu cao cấp, gia công tinh xảo</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/lib/images/Ảnh Trang Chủ/008.jpg" class="d-block w-100 slider-img" alt="Slide 8">
                        <div class="carousel-caption">
                            <h1>ĐỘC NHẤT & SANG TRỌNG</h1>
                            <p>Phong cách Hoàng Gia</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/lib/images/Ảnh Trang Chủ/009.jpg" class="d-block w-100 slider-img" alt="Slide 9">
                        <div class="carousel-caption">
                            <h1>KHÔNG GIAN LÝ TƯỞNG</h1>
                            <p>Thiết kế theo phong cách Châu Âu</p>
                        </div>
                    </div>
                    <div class="carousel-item">
                        <img src="~/lib/images/Ảnh Trang Chủ/010.jpg" class="d-block w-100 slider-img" alt="Slide 10">
                        <div class="carousel-caption">
                            <h1>HOÀN HẢO TỪNG CHI TIẾT</h1>
                            <p>Đẳng cấp - Sang trọng</p>
                        </div>
                    </div>
                </div>

                <!-- Nút điều hướng -->
                <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
            </div>
            @RenderBody()
        </main>
    </div>

    <footer class="main-footer">
        <div class="footer-container">
            <div class="footer-bottom">
                <p>
                    Copyright © 2025 Luxury WMS. All Rights Reserved.
                </p>
                <div class="social-icons">
                    <a href="#"><img src="~/lib/images/Logo/Facebook.jpg" alt="Facebook"></a>
                    <a href="#"><img src="~/lib/images/Logo/Messenger.jpg" alt="Messenger"></a>
                    <a href="#"><img src="~/lib/images/Logo/Zalo.png" alt="Zalo"></a>
                </div>
            </div>
        </div>
    </footer>
        
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
